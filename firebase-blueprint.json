{
  "entities": {
    "products": {
      "title": "Product",
      "description": "Equipamentos para locação",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "totalQuantity": { "type": "integer" }
      },
      "required": ["id", "name", "totalQuantity"]
    },
    "customers": {
      "title": "Customer",
      "description": "Clientes da locadora",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "name", "whatsapp", "address"]
    },
    "rentals": {
      "title": "Rental",
      "description": "Contratos de locação",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "customerId", "items", "startDate", "endDate", "status", "createdAt"]
    },
    "settings": {
      "title": "Settings",
      "description": "Configurações globais",
      "type": "object",
      "properties": {
        "ownerWhatsApp": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "products",
      "description": "Coleção de produtos"
    },
    "/customers/{customerId}": {
      "schema": "customers",
      "description": "Coleção de clientes"
    },
    "/rentals/{rentalId}": {
      "schema": "rentals",
      "description": "Coleção de locações"
    },
    "/settings/global": {
      "schema": "settings",
      "description": "Configurações únicas do sistema"
    }
  }
}
